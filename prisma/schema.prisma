generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ProfileLookup {
  id               String   @id @default(cuid())
  platform         String
  username         String
  profileUrl       String
  profilePicture   String?
  bio              String?
  followers        Int?
  following        Int?
  postCount        Int?
  avgViews         Float?
  avgLikes         Float?
  avgComments      Float?
  avgShares        Float?
  engagementRate   Float?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastSearchedAt   DateTime @default(now())

  contentMetrics ContentMetrics[]

  @@unique([platform, username])
  @@index([lastSearchedAt])
  @@index([platform])
  @@index([followers])
  @@index([engagementRate])
}

model ContentMetrics {
  id               String   @id @default(cuid())
  contentUrl       String
  contentType      String?
  views            Int?
  likes            Int?
  comments         Int?
  shares           Int?
  postedAt         DateTime?
  createdAt        DateTime @default(now())

  profileLookupId String
  profileLookup   ProfileLookup @relation(fields: [profileLookupId], references: [id], onDelete: Cascade)

  @@index([profileLookupId])
}